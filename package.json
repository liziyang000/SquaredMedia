{
  "name": "pingfang-video-template",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "type": "module",
  "scripts": {
    "lint": "npm run lint:frontend",
    "lint:frontend": "npm run lint:js && npm run lint:web && npm run lint:css && npm run format:check",
    "lint:js": "eslint \"template/pingfangvideo/js/*.js\"",
    "lint:web": "npm run lint --workspace @squaredmedia/web",
    "lint:css": "stylelint \"template/pingfangvideo/{css,player}/**/*.css\"",
    "test": "node tests/template.test.mjs && node tests/release-scope.test.mjs && node tests/release-input-fingerprint.test.mjs && node tests/release-cache.test.mjs && node tests/next-deploy-cache-hardening.test.mjs && node tests/deploy-rollback.test.mjs && npm run test:web && php tests/react-api.test.php && php tests/pingfang-api.test.php && php tests/pingfang-api-controller.test.php && php tests/device-session.test.php && php tests/device-controller.test.php && php tests/poster-repair.test.php",
    "test:api": "php tests/pingfang-api.test.php && php tests/pingfang-api-controller.test.php && php tests/device-session.test.php",
    "test:web": "npm run test --workspace @squaredmedia/web",
    "test:e2e": "npm run test:e2e --workspace @squaredmedia/web",
    "typecheck:web": "npm run typecheck --workspace @squaredmedia/web",
    "build:web": "npm run build --workspace @squaredmedia/web",
    "deploy:web": "bash scripts/deploy-next-web.sh",
    "rollback:web": "bash scripts/rollback-next-web.sh",
    "dev:local": "bash scripts/dev-react-local.sh",
    "dev:web": "npm run dev --workspace @squaredmedia/web",
    "lint:template": "node scripts/lint-template.mjs",
    "format": "prettier --write \"template/pingfangvideo/js/*.js\" \"apps/web/**/*.{ts,tsx,json,css,html}\" \"*.config.js\" package.json",
    "format:check": "prettier --check \"template/pingfangvideo/js/*.js\" \"apps/web/**/*.{ts,tsx,json,css,html}\" \"*.config.js\" package.json",
    "verify:compat": "node scripts/verify-compat.mjs",
    "verify:preview": "node scripts/verify-preview.mjs",
    "package": "node scripts/package-theme.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "deploy": "bash scripts/deploy-theme.sh",
    "rollback": "bash scripts/rollback-theme.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.1",
    "stylelint-config-recommended": "^18.0.0"
  }
}
