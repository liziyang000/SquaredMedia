{
  "name": "pingfang-video-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "npm run lint:frontend",
    "lint:frontend": "npm run lint:js && npm run lint:css && npm run format:check",
    "lint:js": "eslint \"template/pingfangvideo/js/*.js\"",
    "lint:css": "stylelint \"template/pingfangvideo/{css,player}/**/*.css\"",
    "test": "node tests/template.test.mjs && php tests/device-session.test.php && php tests/device-controller.test.php && php tests/poster-repair.test.php",
    "lint:template": "node scripts/lint-template.mjs",
    "format": "prettier --write \"template/pingfangvideo/js/*.js\" \"*.config.js\" package.json",
    "format:check": "prettier --check \"template/pingfangvideo/js/*.js\" \"*.config.js\" package.json",
    "verify:compat": "node scripts/verify-compat.mjs",
    "verify:preview": "node scripts/verify-preview.mjs",
    "package": "node scripts/package-theme.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "deploy": "bash scripts/deploy-theme.sh",
    "rollback": "bash scripts/rollback-theme.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.1",
    "stylelint-config-recommended": "^18.0.0"
  }
}
